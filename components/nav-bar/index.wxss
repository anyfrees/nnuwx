/* ===== 透明模式：无背景、无模糊，白色文字 + 底部渐变遮罩 ===== */
.nav-bar.nav-transparent {
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border-bottom: none;
  box-shadow: none;
}

/* 透明模式下叠加一个渐变遮罩，让文字在浅色背景上也能看清 */
.nav-bar.nav-transparent::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.25) 0%, transparent 100%);
  pointer-events: none;
  z-index: 0;
}

.nav-bar.nav-transparent .nav-content {
  position: relative;
  z-index: 1;
}

.nav-bar.nav-transparent .nav-title {
  color: #FFFFFF;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.45);
}
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;

  /* 横向通栏液态毛玻璃：半透明 + 高高斯模糊 */
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(28px) saturate(180%);
  -webkit-backdrop-filter: blur(28px) saturate(180%);

  /* 微光底部边框，模拟悬浮玻璃边缘 */
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);

  /* 柔和悬浮阴影 */
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06),
              0 1rpx 0 rgba(255, 255, 255, 0.15);
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  letter-spacing: 3rpx;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.5);
}
