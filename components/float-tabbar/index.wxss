/**
 * iOS 18 / VisionOS 风格悬浮胶囊 TabBar 样式（与首页自定义 TabBar 一致）
 * 设计语言：悬浮胶囊 + 毛玻璃 + 分离式搜索球 + 选中态高亮背板 + 弥散阴影
 */

/* ===== 底部悬浮容器 ===== */
.custom-tabbar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 999;
  pointer-events: none;         /* 容器不拦截触摸，由子元素接管 */
}

/* ===== 主导航胶囊卡片 ===== */
.tabbar-main {
  flex: 1;
  margin-right: 16rpx;
  height: 110rpx;
  border-radius: 55rpx;

  /* 毛玻璃核心：高透明度白色 + 强高斯模糊 */
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);

  /* 弥散阴影：多层次叠加，模拟自然光影 */
  box-shadow:
    0 10rpx 32rpx rgba(0, 0, 0, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);

  /* 极细白边，模拟玻璃边缘的高光 */
  border: 1rpx solid rgba(255, 255, 255, 0.55);

  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  padding: 0 12rpx;

  pointer-events: auto;
}

/* ===== 单个 Tab 项 ===== */
.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 6rpx 18rpx;
  border-radius: 36rpx;
  gap: 2rpx;
  transition: all 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
  transform: scale(1);
}

/* 点击缩放回弹 */
.tab-item:active {
  transform: scale(0.9);
}

/* ===== 选中态：浅灰色圆角高亮背板 ===== */
.tab-item.active {
  background-color: rgba(0, 0, 0, 0.06);
}

/* ===== 图标 ===== */
.tab-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  transition: all 0.25s ease;
}

/* ===== 文字 ===== */
.tab-text {
  font-size: 20rpx;
  color: #000000;
  font-weight: 500;
  line-height: 1.2;
  flex-shrink: 0;
  transition: color 0.25s ease;
}

.tab-text.active {
  color: #1677FF;
  font-weight: 700;
}

/* ===== 角标 ===== */
.tab-badge {
  position: absolute;
  top: 8rpx;
  right: 4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background: #FF3B30;
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 6rpx rgba(255, 59, 48, 0.35);
}

/* ===== 右侧独立搜索球 ===== */
.tabbar-search-btn {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  flex-shrink: 0;

  /* 毛玻璃 */
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);

  /* 弥散阴影 */
  box-shadow:
    0 10rpx 32rpx rgba(0, 0, 0, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);

  /* 极细白边 */
  border: 1rpx solid rgba(255, 255, 255, 0.55);

  display: flex;
  align-items: center;
  justify-content: center;

  pointer-events: auto;
  transition: transform 0.2s ease;
}

/* 点击缩放回弹 */
.tabbar-search-btn:active {
  transform: scale(0.88);
}

/* 搜索图标 */
.tabbar-search-btn .search-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.75;
}
