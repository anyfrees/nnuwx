/*
 * NNU技术博客 ZeroWe - 全局样式
 * 设计语言：玻璃拟态 + 卡片式 + 留白 + 动效
 * 参考：Apple HIG / 少数派 / 微信读书
 */

/* ========== CSS 变量（主题色） ========== */
page {
  --bg-primary: #F0F2F5;
  --bg-card: rgba(255,255,255,0.50);
  --bg-card-glass: rgba(255,255,255,0.35);
  --bg-input: rgba(240,242,245,0.6);
  --text-primary: #1A1A2E;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --brand-primary: #1677FF;
  --brand-accent: #00C2FF;
  --brand-highlight: #FFB800;
  --border-color: rgba(0,0,0,0.06);
  --border-glass: rgba(255,255,255,0.25);
  --shadow-card: 0 8rpx 32rpx rgba(0,0,0,0.06);
  --shadow-float: 0 16rpx 48rpx rgba(0,0,0,0.10);
  --nav-bg: rgba(240,242,245,0.50);
  --divider: rgba(0,0,0,0.06);

  background: #F0F2F5;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  color: var(--text-primary);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  font-size: 28rpx;
}

/* 暗黑模式已移除，仅保留浅色模式 */

/* ========== 通用组件 ========== */
view, text, image, input, button, scroll-view, swiper, swiper-item, block, navigator {
  box-sizing: border-box;
}

/* 强磨砂玻璃（用于搜索栏、导航等） */
.glass-card {
  background: var(--bg-card-glass);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 1rpx solid var(--border-glass);
  border-radius: 48rpx;
  box-shadow: var(--shadow-card);
}

/* 磨砂玻璃卡片（全局统一） */
.card {
  background: var(--bg-card);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  box-shadow: var(--shadow-card);
  overflow: hidden;
  border: 1rpx solid var(--border-glass);
}

/* 圆角胶囊 */
.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.25s ease;
}

.pill-active {
  background: var(--brand-primary);
  color: #FFFFFF;
}

/* 品牌色按钮 */
.btn-primary {
  background: linear-gradient(135deg, #1677FF 0%, #00C2FF 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  font-weight: 600;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  box-shadow: 0 6rpx 20rpx rgba(22,119,255,0.25);
  transition: all 0.2s ease;
}
.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.85;
}

/* 次要按钮 */
.btn-secondary {
  background: var(--bg-card);
  color: var(--brand-primary);
  border: 2rpx solid var(--brand-primary);
  border-radius: 44rpx;
  font-weight: 600;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  transition: all 0.2s ease;
}
.btn-secondary:active {
  background: rgba(22,119,255,0.08);
  transform: scale(0.96);
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(135deg, #1677FF 0%, #00C2FF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, var(--border-color) 25%, transparent 50%, var(--border-color) 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease infinite;
  border-radius: 12rpx;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 淡入动画 */
.fade-in {
  animation: fadeIn 0.5s ease both;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 卡片悬浮动画 */
.float-up {
  animation: floatUp 0.6s ease both;
}

@keyframes floatUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 点击涟漪 */
.ripple {
  position: relative;
  overflow: hidden;
}

.ripple:active::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(22,119,255,0.15);
  transform: translate(-50%, -50%);
  animation: rippleEffect 0.6s ease-out;
}

@keyframes rippleEffect {
  to { width: 600rpx; height: 600rpx; opacity: 0; }
}

/* 通用页面容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: 20rpx;
  background: transparent;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}

/* ========== 图标系统 ========== */
.icon-sm {
  width: 32rpx;
  height: 32rpx;
  vertical-align: middle;
  display: inline-block;
}
.icon-md {
  width: 40rpx;
  height: 40rpx;
  vertical-align: middle;
  display: inline-block;
}
.icon-lg {
  width: 56rpx;
  height: 56rpx;
  vertical-align: middle;
  display: inline-block;
}
.icon-xl {
  width: 100rpx;
  height: 100rpx;
  display: block;
}
