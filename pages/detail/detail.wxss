.detail-container {
  padding-bottom: 140rpx;
  background: #FFFFFF;
  min-height: 100vh;
}

.cover-banner {
  width: 100%;
  height: 380rpx;
  display: block;
  background: #E2E8F0;
}

.article-header {
  padding: 40rpx 36rpx 20rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.4;
  color: #0F172A;
  margin-bottom: 24rpx;
  display: block;
}

.meta-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 20rpx;
}

.author-block {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #1E293B;
  font-weight: 600;
}

.categories-row {
  display: flex;
  gap: 12rpx;
}

.cat-tag {
  background: #E8F5E9;
  color: #07C160;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.rich-content {
  padding: 36rpx;
  font-size: 32rpx;
  line-height: 1.8;
  color: #334155;
}

.tags-section {
  padding: 20rpx 36rpx 40rpx;
  border-top: 1rpx solid #F1F5F9;
}

.section-title {
  font-size: 26rpx;
  color: #64748B;
  display: block;
  margin-bottom: 16rpx;
}

.tag-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  background: #F8FAFC;
  border: 1rpx solid #E2E8F0;
  color: #475569;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-top: 1rpx solid #E2E8F0;
  padding: 20rpx 36rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -8rpx 20rpx rgba(0,0,0,0.03);
  z-index: 100;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  padding: 18rpx 0;
}

.share-btn {
  background: #F1F5F9;
  color: #1E293B;
}

.contact-btn {
  background: #07C160;
  color: #FFFFFF;
}