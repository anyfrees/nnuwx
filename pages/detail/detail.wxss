/* ================================================================
 * 文章详情页 UI - 深色沉浸式 Hero + 浅色极简阅读主体
 * 设计语言：Dark Hero Header + Clean Body + Glassmorphism
 * ================================================================ */

/* ===== 页面容器 ===== */
.page-container {
  min-height: 100vh;
  background: #F0F2F5;
  padding-bottom: 0;
}

/* ================================================================
 * 1. 沉浸式文章 Header 区域（Hero Section）
 * ================================================================ */
.article-header {
  position: relative;
  width: 100%;
  min-height: 560rpx;
  padding: 160rpx 36rpx 120rpx 36rpx;
  background-color: #1a1c23;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  overflow: hidden;
}

/* 背景封面图 — 不使用 CSS filter（小程序原生 image 不支持 blur），改用遮罩增强 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  transform: scale(1.1);
  z-index: 1;
}

/* 更强的遮罩层补偿缺少的 blur，确保文字始终可读 */
.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(ellipse at center, rgba(0, 0, 0, 0.35) 0%, rgba(0, 0, 0, 0.65) 100%),
    linear-gradient(180deg, rgba(26, 28, 35, 0.55) 0%, rgba(0, 0, 0, 0.8) 100%);
  z-index: 1;
}

/* 前景内容区 */
.header-content {
  position: relative;
  z-index: 2;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== 玻璃拟态分类胶囊标签 ===== */
.header-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  justify-content: center;
  margin-bottom: 28rpx;
}

.badge-item {
  background: rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
  padding: 8rpx 26rpx;
  border-radius: 40rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* ===== 主标题 ===== */
.header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.4;
  text-align: center;
  max-width: 640rpx;
  text-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.5);
  margin-bottom: 32rpx;
}

/* ===== 文章元数据网格 ===== */
.header-meta-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: center;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 28rpx;
  justify-content: center;
  align-items: center;
}

.meta-cell {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon-sm {
  width: 28rpx;
  height: 28rpx;
  vertical-align: middle;
  opacity: 0.75;
}

.meta-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* ================================================================
 * 2. 内容主体容器（Main Content Container）
 * ================================================================ */
.article-body-card {
  position: relative;
  margin-top: -80rpx;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 40rpx 40rpx 0 0;
  padding: 0;
  z-index: 3;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.08);
}

/* ===== 正文内容 ===== */
.article-body-card .content-body {
  padding: 36rpx 32rpx;
  font-size: 30rpx;
  line-height: 1.9;
  color: var(--text-primary);
  background: transparent;
  position: relative;
  z-index: 2;
}

.article-body-card .content-body h1,
.article-body-card .content-body h2,
.article-body-card .content-body h3 {
  margin: 32rpx 0 16rpx;
  line-height: 1.3;
}

.article-body-card .content-body img {
  max-width: 100% !important;
  height: auto !important;
  display: block !important;
  margin: 24rpx auto !important;
  border-radius: 12rpx !important;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08) !important;
}

.article-body-card .content-body pre {
  background: var(--bg-input);
  border-radius: 16rpx;
  padding: 20rpx;
  overflow-x: auto;
  margin: 20rpx 0;
}

.article-body-card .content-body code {
  font-family: 'SF Mono', 'Fira Code', monospace;
  font-size: 26rpx;
  background: var(--bg-input);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.article-body-card .content-body blockquote {
  border-left: 4rpx solid var(--brand-primary);
  padding: 16rpx 24rpx;
  margin: 20rpx 0;
  background: rgba(22, 119, 255, 0.04);
  border-radius: 0 12rpx 12rpx 0;
}

.article-body-card .content-body table {
  width: 100%;
  border-collapse: collapse;
  margin: 20rpx 0;
}

.article-body-card .content-body td,
.article-body-card .content-body th {
  border: 1rpx solid var(--divider);
  padding: 12rpx 16rpx;
}

.article-body-card .content-body ul,
.article-body-card .content-body ol {
  padding-left: 32rpx;
  margin: 16rpx 0;
}

.article-body-card .content-body a {
  color: var(--brand-primary);
  text-decoration: none;
}

.article-body-card .content-body hr {
  border: none;
  border-top: 1rpx solid var(--divider);
  margin: 32rpx 0;
}

/* ===== 标签区域 ===== */
.content-tags {
  padding: 20rpx 32rpx 28rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
  background: transparent;
  position: relative;
  z-index: 2;
}

.tags-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.tag-item {
  background: var(--bg-input);
  color: var(--text-secondary);
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: inline-block;
}

/* ================================================================
 * 3. 右侧悬浮工具栏（Floating Side Toolbar）
 * ================================================================ */
.floating-toolbar {
  position: fixed;
  right: 24rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 99;
  opacity: 0;
  transform: translateX(20rpx);
  transition: opacity 0.35s ease, transform 0.35s ease;
  pointer-events: none;
}

.floating-toolbar.toolbar-visible {
  opacity: 1;
  transform: translateX(0);
  pointer-events: auto;
}

.toolbar-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(44, 62, 80, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  transition: all 0.2s ease;
}

.toolbar-btn:active {
  background: rgba(22, 119, 255, 0.85);
  transform: scale(0.92);
}

.toolbar-arrow {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 700;
  line-height: 1;
}

/* ===== 相关推荐 ===== */
.related-section {
  padding: 10rpx 20rpx 20rpx;
}

.section-header {
  padding: 20rpx 16rpx 12rpx;
  display: flex;
  align-items: center;
}

.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.related-card {
  display: flex;
  padding: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
}

.related-cover {
  width: 140rpx;
  height: 100rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: var(--bg-input);
}

.related-body {
  flex: 1;
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.related-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.related-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== 底部操作栏（文章操作：收藏/评论/分享/复制） ===== */
.bottom-bar {
  position: fixed;
  bottom: calc(16rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 110rpx;
  margin: 0 24rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  box-shadow:
    0 10rpx 32rpx rgba(0, 0, 0, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 55rpx;
  z-index: 998;
  box-sizing: border-box;
  padding: 0 12rpx;
}

.bar-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0;
  gap: 2rpx;
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  border: none;
  background: transparent;
  transition: all 0.2s ease;
}

.bar-action:active {
  background: rgba(22, 119, 255, 0.08);
  transform: scale(0.92);
}

.share-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0;
  gap: 2rpx;
  border: none;
  background: transparent;
  line-height: 1;
  font-size: inherit;
  border-radius: 20rpx;
}

.share-btn:active {
  background: rgba(22, 119, 255, 0.08);
  transform: scale(0.92);
}

.share-btn::after {
  border: none;
}

.bar-icon-img {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  filter: brightness(0);
}

.bar-label {
  font-size: 20rpx;
  color: #000000;
  font-weight: 500;
  line-height: 1.2;
  flex-shrink: 0;
  transition: color 0.25s ease;
}

.bar-action.favorited .bar-icon-img {
  filter: none;
}

.bar-action.favorited .bar-label {
  color: #FFB800;
  font-weight: 700;
}

/* ===== 空状态 ===== */
.empty-box {
  text-align: center;
  padding: 200rpx 40rpx;
}

.empty-icon-img {
  width: 120rpx;
  height: 120rpx;
  display: block;
  margin: 0 auto 20rpx;
  opacity: 0.35;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-tertiary);
  display: block;
}
