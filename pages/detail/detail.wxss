/* ===== 封面大图 ===== */
.hero-section {
  position: relative;
  width: 100%;
  height: 480rpx;
  overflow: hidden;
}
.hero-cover {
  width: 100%;
  height: 100%;
}
.hero-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.75));
}
.hero-info {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
}
.hero-title {
  color: #FFF;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.3;
  display: block;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.4);
  margin-bottom: 16rpx;
}
.hero-meta {
  display: flex;
  gap: 12rpx;
}
.hero-cat {
  background: rgba(255,255,255,0.22);
  backdrop-filter: blur(10px);
  color: #FFF;
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 元信息 ===== */
.meta-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 36rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.meta-left, .meta-right {
  display: flex;
  gap: 24rpx;
}

/* ===== 正文卡片 ===== */
.content-card {
  margin: 0 20rpx 30rpx;
  border-radius: 24rpx;
  overflow: visible;
  background: var(--bg-card);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-glass);
}
.content-body {
  padding: 36rpx 32rpx;
  font-size: 30rpx;
  line-height: 1.9;
  color: var(--text-primary);
}
.content-body h1,
.content-body h2,
.content-body h3 {
  margin: 32rpx 0 16rpx;
  line-height: 1.3;
}
.content-body img {
  max-width: 100% !important;
  height: auto !important;
  display: block !important;
  margin: 24rpx auto !important;
  border-radius: 12rpx !important;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08) !important;
}
.content-body pre {
  background: var(--bg-input);
  border-radius: 16rpx;
  padding: 20rpx;
  overflow-x: auto;
  margin: 20rpx 0;
}
.content-body code {
  font-family: 'SF Mono', 'Fira Code', monospace;
  font-size: 26rpx;
  background: var(--bg-input);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}
.content-body blockquote {
  border-left: 4rpx solid var(--brand-primary);
  padding: 16rpx 24rpx;
  margin: 20rpx 0;
  background: rgba(22,119,255,0.04);
  border-radius: 0 12rpx 12rpx 0;
}
.content-body table {
  width: 100%;
  border-collapse: collapse;
  margin: 20rpx 0;
}
.content-body td,
.content-body th {
  border: 1rpx solid var(--divider);
  padding: 12rpx 16rpx;
}
.content-body ul, .content-body ol {
  padding-left: 32rpx;
  margin: 16rpx 0;
}
.content-body a {
  color: var(--brand-primary);
  text-decoration: none;
}
.content-body hr {
  border: none;
  border-top: 1rpx solid var(--divider);
  margin: 32rpx 0;
}

/* ===== 标签 ===== */
.content-tags {
  padding: 20rpx 32rpx 28rpx;
  border-top: 1rpx solid var(--divider);
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}
.tags-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}
.tag-item {
  background: var(--bg-input);
  color: var(--text-secondary);
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: inline-block;
}

/* ===== 相关推荐 ===== */
.related-section {
  padding: 10rpx 20rpx 20rpx;
}
.related-card {
  display: flex;
  padding: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
}
.related-cover {
  width: 140rpx;
  height: 100rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: var(--bg-input);
}
.related-body {
  flex: 1;
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.related-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.related-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 68rpx;
  margin: 0 32rpx 20rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.10);
  backdrop-filter: blur(50px) saturate(200%);
  -webkit-backdrop-filter: blur(50px) saturate(200%);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 999rpx;
  box-shadow:
    0 4rpx 20rpx rgba(0, 0, 0, 0.05),
    0 1rpx 6rpx rgba(0, 0, 0, 0.03),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.20);
  z-index: 100;
  box-sizing: content-box;
}
.bar-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0;
  gap: 2rpx;
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  border: none;
  background: transparent;
  transition: all 0.2s ease;
}
.bar-action:active {
  background: rgba(22,119,255,0.08);
  transform: scale(0.92);
}
.share-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0;
  gap: 2rpx;
  border: none;
  background: transparent;
  line-height: 1;
  font-size: inherit;
  border-radius: 20rpx;
}
.share-btn:active {
  background: rgba(22,119,255,0.08);
  transform: scale(0.92);
}
.share-btn::after {
  border: none;
}
.bar-icon-img {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}
.bar-label {
  font-size: 20rpx;
  color: #1A1A2E;
  font-weight: 500;
  line-height: 1.2;
  flex-shrink: 0;
}

/* ===== 空状态 ===== */
.empty-box {
  text-align: center;
  padding: 200rpx 40rpx;
}
.empty-icon-img {
  width: 120rpx;
  height: 120rpx;
  display: block;
  margin: 0 auto 20rpx;
  opacity: 0.35;
}
.empty-text {
  font-size: 30rpx;
  color: var(--text-tertiary);
  display: block;
}
