.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 36rpx;
}
.header-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.clear-btn {
  font-size: 24rpx;
  color: #EF4444;
}
.fav-card {
  margin: 0 30rpx 20rpx;
  overflow: hidden;
}
.fav-main {
  display: flex;
  padding: 20rpx;
}
.fav-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: var(--bg-input);
}
.fav-body {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}
.fav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.fav-excerpt {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 10rpx;
}
.fav-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.fav-cat {
  color: var(--brand-primary);
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: inline-block;
}
.fav-action {
  border-top: 1rpx solid var(--divider);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.fav-action:active {
  background: var(--bg-input);
}
.empty-state {
  text-align: center;
  padding: 160rpx 40rpx;
}
.empty-icon-img {
  width: 100rpx;
  height: 100rpx;
  display: block;
  margin: 0 auto 20rpx;
  opacity: 0.35;
}
.empty-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); display: block; margin-bottom: 10rpx; }
.empty-desc { font-size: 26rpx; color: var(--text-tertiary); display: block; }
