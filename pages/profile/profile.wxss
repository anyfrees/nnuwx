/* 统计面板 */
.stats-grid {
  display: flex;
  margin: 30rpx 30rpx 24rpx;
  gap: 14rpx;
}
.stat-card {
  flex: 1;
  padding: 28rpx 8rpx;
  text-align: center;
}
.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--brand-primary);
  display: block;
  margin-bottom: 6rpx;
}
.stat-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 菜单 */
.menu-section {
  margin: 0 30rpx;
}
.menu-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  margin-bottom: 12rpx;
}
.menu-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
}
.menu-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}
.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.menu-value {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.menu-badge {
  background: var(--brand-primary);
  color: #FFF;
  font-size: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 10rpx;
}
.menu-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

/* 外观模式指示器 */
.theme-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.theme-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  display: inline-block;
}
.dot-light {
  background: #FFB800;
  box-shadow: 0 0 8rpx rgba(255,184,0,0.5);
}
.dot-dark {
  background: #6366F1;
  box-shadow: 0 0 8rpx rgba(99,102,241,0.5);
}
.dot-auto {
  background: linear-gradient(135deg, #FFB800 50%, #6366F1 50%);
  box-shadow: 0 0 8rpx rgba(99,102,241,0.4);
}

/* 联系我 - 透明覆盖层按钮 */
.menu-contact {
  position: relative;
}
.contact-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  opacity: 0;
  z-index: 1;
}
.contact-overlay::after {
  border: none !important;
  border-radius: 0;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 48rpx 36rpx;
}
.footer-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  display: block;
}

/* ===== iOS 18 悬浮胶囊 TabBar 底部预留（110rpx 胶囊 + 16rpx 间距 + 安全区） ===== */
.page-container {
  padding-bottom: 180rpx !important;
}
