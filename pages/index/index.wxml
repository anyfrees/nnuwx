<view class="page-container">

  <!-- ===== 自定义导航栏 ===== -->
  <view class="nav-bar" style="height:{{navHeight}}px; padding-top:{{statusBarHeight}}px;">
    <view class="nav-content">
      <text class="nav-title">NNU技术博客</text>
    </view>
  </view>

  <!-- ===== 搜索入口 ===== -->
  <view class="brand-section fade-in">
    <view class="search-entry glass-card ripple" bindtap="goSearch">
      <image class="search-icon-img" src="/images/icons/search.png" mode="aspectFit"/>
      <text class="search-placeholder">搜索文章、标签、关键词...</text>
    </view>
  </view>

  <!-- ===== 轮播 Banner ===== -->
  <view class="banner-section fade-in" wx:if="{{banners.length > 0}}">
    <view class="banner-header">
      <text class="section-label"><image class="icon-md" src="/images/icons/sparkle.png" mode="aspectFit"/> 随机推荐</text>
    </view>
    <swiper 
      class="banner-swiper" 
      indicator-dots="{{true}}" 
      indicator-color="rgba(255,255,255,0.4)"
      indicator-active-color="#FFFFFF"
      autoplay="{{true}}" 
      interval="4000" 
      duration="500"
      circular="{{true}}"
      bindchange="onBannerChange"
    >
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-card" bindtap="onBannerTap" data-id="{{item.id}}">
          <image class="banner-img" src="{{item.cover}}" mode="aspectFill" lazy-load/>
          <view class="banner-mask"></view>
          <view class="banner-info">
            <text class="banner-cat">{{item.category}}</text>
            <text class="banner-title">{{item.title}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- ===== 分类胶囊 ===== -->
  <view class="category-section fade-in">
    <view class="section-header">
      <text class="section-label"><image class="icon-md" src="/images/icons/folder.png" mode="aspectFit"/> 探索分类</text>
    </view>
    <scroll-view scroll-x class="cat-scroll" show-scrollbar="{{false}}" enhanced>
      <view class="cat-capsule {{activeCategory === '' && activeTag === '' ? 'cat-active' : ''}}" 
            bindtap="onCategoryTap" data-cat="全部">
        <image class="cat-icon" src="/images/icons/clipboard.png" mode="aspectFit"/>
        <text>全部</text>
      </view>
      <view class="cat-capsule {{activeCategory === item.key ? 'cat-active' : ''}}" wx:for="{{categories}}" wx:key="key" 
            bindtap="onCategoryTap" data-cat="{{item.key}}">
        <image class="cat-icon" src="{{item.icon}}" mode="aspectFit"/>
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- ===== 文章列表 ===== -->
  <view class="article-section">
    <view class="section-header">
      <text class="section-label"><image class="icon-md" src="/images/icons/document.png" mode="aspectFit"/> 最新文章</text>
    </view>

    <!-- 骨架屏加载 -->
    <block wx:if="{{loading && filteredArticles.length === 0}}">
      <view class="article-card glass-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton" style="height:320rpx;width:100%;border-radius:0;"></view>
        <view class="card-body">
          <view class="skeleton" style="height:28rpx;width:30%;margin-bottom:16rpx;"></view>
          <view class="skeleton" style="height:40rpx;width:80%;margin-bottom:12rpx;"></view>
          <view class="skeleton" style="height:24rpx;width:100%;margin-bottom:20rpx;"></view>
          <view class="skeleton" style="height:22rpx;width:50%;"></view>
        </view>
      </view>
    </block>

    <!-- 文章卡片 -->
    <block wx:for="{{filteredArticles}}" wx:key="id" wx:for-item="item" wx:for-index="idx">
      <view class="article-card float-up" style="animation-delay:{{idx * 0.08}}s;" 
            bindtap="onArticleTap" data-id="{{item.id}}">
        <view class="card-cover-wrap">
          <image class="card-cover" src="{{item.coverImage}}" mode="aspectFill" lazy-load/>
          <view class="card-cover-gradient"></view>
          <view class="card-cat-badge">{{item.categories[0] || '文章'}}</view>
        </view>
        <view class="card-body">
          <text class="card-title">{{item.title}}</text>
          <text class="card-excerpt">{{item.excerpt}}</text>
          <view class="card-footer">
            <text class="card-date"><image class="icon-sm" src="/images/icons/calendar.png" mode="aspectFit"/> {{item.date}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && filteredArticles.length === 0}}">
      <image class="empty-icon-img" src="/images/icons/empty.png" mode="aspectFit"/>
      <text class="empty-title">暂无文章</text>
      <text class="empty-desc">下拉刷新试试看</text>
    </view>
  </view>

</view>
