<!-- 液态毛玻璃导航栏 -->
<nav-bar title="NNU技术博客" />

<view class="page-container">

  <!-- ===== Bento Box 液态毛玻璃网格区 ===== -->
  <view class="bento-grid">

    <!-- 左侧列：两个堆叠小卡片（随机栏目名称动态展示） -->
    <view class="bento-left">

      <!-- 左上：随机栏目卡片 - 蓝色液态毛玻璃 -->
      <view class="bento-card glass-bento-card blue" bindtap="onLeftTopTap">
        <view class="bento-card-watermark">
          <image class="watermark-icon" src="/images/icons/sparkle.png" mode="aspectFit"/>
        </view>
        <view class="bento-card-content">
          <text class="bento-card-label">{{leftTopCard.name || '栏目'}}</text>
          <text class="bento-card-value">{{leftTopCard.count || 0}}</text>
          <text class="bento-card-sub">篇文章</text>
        </view>
        <view class="bento-card-glow"></view>
      </view>

      <!-- 左下：随机栏目卡片 - 橙色液态毛玻璃 -->
      <view class="bento-card glass-bento-card orange" bindtap="onLeftBottomTap">
        <view class="bento-card-watermark">
          <image class="watermark-icon" src="/images/icons/globe.png" mode="aspectFit"/>
        </view>
        <view class="bento-card-content">
          <text class="bento-card-label">{{leftBottomCard.name || '栏目'}}</text>
          <text class="bento-card-value">{{leftBottomCard.count || 0}}</text>
          <text class="bento-card-sub">篇文章</text>
        </view>
        <view class="bento-card-glow"></view>
      </view>

    </view>

    <!-- 右侧大卡片：精选文章 swiper 轮播（3篇动态滚动） -->
    <view class="bento-right">
      <view class="bento-card bento-featured glass-bento-card" wx:if="{{featuredArticles.length > 0}}">
        <swiper
          class="bento-featured-swiper"
          autoplay="{{true}}"
          interval="3500"
          duration="600"
          circular="{{true}}"
          bindchange="onFeaturedSwiperChange"
        >
          <swiper-item wx:for="{{featuredArticles}}" wx:key="id">
            <view class="bento-featured-slide" bindtap="onFeaturedTap" data-id="{{item.id}}">
              <image class="bento-featured-cover" src="{{item.coverImage}}" mode="aspectFill"/>
              <view class="bento-featured-mask"></view>
              <!-- 底部毛玻璃文字底座 -->
              <view class="bento-featured-info">
                <text class="bento-featured-cat">{{item.category}}</text>
                <text class="bento-featured-title">{{item.title}}</text>
                <text class="bento-featured-excerpt">{{item.excerpt}}</text>
              </view>
            </view>
          </swiper-item>
        </swiper>
        <!-- 自定义指示器：3个点的进度条 -->
        <view class="bento-swiper-dots">
          <view class="bento-swiper-dot {{featuredSwiperIdx === 0 ? 'active' : ''}}"></view>
          <view class="bento-swiper-dot {{featuredSwiperIdx === 1 ? 'active' : ''}}"></view>
          <view class="bento-swiper-dot {{featuredSwiperIdx === 2 ? 'active' : ''}}"></view>
        </view>
        <view class="bento-card-glow"></view>
      </view>
      <!-- 无数据时的占位 -->
      <view class="bento-card bento-featured glass-bento-card bento-featured-placeholder" wx:else>
        <view class="bento-placeholder-content">
          <image class="bento-placeholder-icon" src="/images/icons/rocket.png" mode="aspectFit"/>
          <text class="bento-placeholder-text">正在加载精选内容…</text>
        </view>
      </view>
    </view>

  </view>

  <!-- ===== 分类 Tab 栏 - 液态玻璃胶囊 ===== -->
  <view class="category-tabs">
    <scroll-view scroll-x class="cat-tabs-scroll" show-scrollbar="{{false}}" enhanced>
      <!-- 全部 -->
      <view class="cat-tab-pill {{activeCategory === '' && activeTag === '' ? 'cat-tab-active' : ''}}" 
            bindtap="onCategoryTap" data-cat="全部">
        <text class="cat-tab-text">全部</text>
      </view>
      <!-- 分类项 -->
      <view class="cat-tab-pill {{activeCategory === item.key ? 'cat-tab-active' : ''}}" 
            wx:for="{{categoriesWithStyle}}" wx:key="key" 
            bindtap="onCategoryTap" data-cat="{{item.key}}">
        <image class="cat-tab-icon-sm" src="{{item.icon}}" mode="aspectFit"/>
        <text class="cat-tab-text">{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- ===== 文章列表 ===== -->
  <view class="article-section">
    <view class="section-header">
      <view class="section-header-left">
        <image class="icon-md" src="/images/icons/document.png" mode="aspectFit"/>
        <text class="section-label">最新文章</text>
      </view>
      <text class="section-count" wx:if="{{filteredArticles.length > 0}}">共 {{filteredArticles.length}} 篇</text>
    </view>

    <!-- 骨架屏加载 -->
    <block wx:if="{{loading && filteredArticles.length === 0}}">
      <view class="article-card glass-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton" style="height:320rpx;width:100%;border-radius:0;"></view>
        <view class="card-body">
          <view class="skeleton" style="height:28rpx;width:30%;margin-bottom:16rpx;"></view>
          <view class="skeleton" style="height:40rpx;width:80%;margin-bottom:12rpx;"></view>
          <view class="skeleton" style="height:24rpx;width:100%;margin-bottom:20rpx;"></view>
          <view class="skeleton" style="height:22rpx;width:50%;"></view>
        </view>
      </view>
    </block>

    <!-- 文章卡片 -->
    <block wx:for="{{filteredArticles}}" wx:key="id" wx:for-item="item" wx:for-index="idx">
      <view class="article-card float-up" style="animation-delay:{{idx * 0.08}}s;" 
            bindtap="onArticleTap" data-id="{{item.id}}">
        <view class="card-cover-wrap">
          <image class="card-cover" src="{{item.coverImage}}" mode="aspectFill" lazy-load/>
          <view class="card-cover-gradient"></view>
          <view class="card-cat-badge">{{item.categories[0] || '文章'}}</view>
        </view>
        <view class="card-body">
          <text class="card-title">{{item.title}}</text>
          <text class="card-excerpt">{{item.excerpt}}</text>
          <view class="card-footer">
            <text class="card-date"><image class="icon-sm" src="/images/icons/calendar.png" mode="aspectFit"/> {{item.date}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && filteredArticles.length === 0}}">
      <image class="empty-icon-img" src="/images/icons/empty.png" mode="aspectFit"/>
      <text class="empty-title">暂无文章</text>
      <text class="empty-desc">下拉刷新试试看</text>
    </view>
  </view>

</view>
