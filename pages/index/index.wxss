/* ===== 自定义导航栏 ===== */
.nav-bar {
  background: var(--nav-bg);
  backdrop-filter: blur(28px);
  -webkit-backdrop-filter: blur(28px);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid var(--border-glass);
}
.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

/* ===== 搜索区 ===== */
.brand-section {
  padding: 32rpx 36rpx 8rpx;
}
.search-entry {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
}
.search-icon-img {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.search-placeholder {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ===== Banner ===== */
.banner-section {
  padding: 0 36rpx 28rpx;
}
.banner-header {
  margin-bottom: 16rpx;
}
.section-label {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.banner-swiper {
  width: 100%;
  height: 340rpx;
  border-radius: 28rpx;
  overflow: hidden;
}
.banner-card {
  width: 100%;
  height: 100%;
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
}
.banner-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.65));
}
.banner-info {
  position: absolute;
  bottom: 28rpx;
  left: 28rpx;
  right: 28rpx;
}
.banner-cat {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(10px);
  color: #FFF;
  font-size: 20rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.banner-title {
  color: #FFF;
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

/* ===== 分类区 ===== */
.category-section {
  padding: 0 36rpx 24rpx;
}
.section-header {
  margin-bottom: 16rpx;
}
.cat-scroll {
  white-space: nowrap;
  padding: 8rpx 0;
}
.cat-capsule {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 44rpx;
  background: rgba(255,255,255,0.72);
  font-size: 26rpx;
  color: var(--text-secondary);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.05);
  transition: all 0.25s ease;
}
.cat-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}
.cat-capsule:active {
  transform: scale(0.95);
  background: var(--brand-primary);
  color: #FFF;
}
.cat-active {
  background: linear-gradient(135deg, #1677FF, #00C2FF) !important;
  color: #FFF !important;
  border-color: transparent !important;
}

/* ===== 文章列表 ===== */
.article-section {
  padding: 36rpx 36rpx 20rpx;
}
.article-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-glass);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  transition: transform 0.3s ease;
}
.article-card:active {
  transform: scale(0.98);
}
.card-cover-wrap {
  position: relative;
  width: 100%;
  height: 340rpx;
  overflow: hidden;
}
.card-cover {
  width: 100%;
  height: 100%;
}
.card-cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}
.card-cat-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(10px);
  color: var(--brand-primary);
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 600;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-body {
  padding: 24rpx 28rpx 28rpx;
}
.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.card-excerpt {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--divider);
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.card-stats {
  display: flex;
  gap: 24rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}
.empty-icon-img {
  width: 120rpx;
  height: 120rpx;
  display: block;
  margin: 0 auto 20rpx;
  opacity: 0.4;
}
.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 10rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  display: block;
}

/* ===== 自定义 TabBar 底部安全区 ===== */
.page-container {
  padding-bottom: 150rpx !important;
}
