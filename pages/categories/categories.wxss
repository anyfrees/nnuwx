/* Segment 控制条 */
.seg-bar {
  display: flex;
  margin: 24rpx 36rpx;
  background: var(--bg-card);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 40rpx;
  padding: 6rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-glass);
}
.seg-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 36rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}
.seg-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}
.seg-active {
  background: linear-gradient(135deg, #1677FF, #00C2FF);
  color: #FFF;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(22,119,255,0.3);
}

/* 九宫格 */
.grid-container {
  display: flex;
  flex-wrap: wrap;
  padding: 10rpx 30rpx 20rpx;
  justify-content: space-between;
}
.grid-card {
  width: calc(33.33% - 16rpx);
  padding: 32rpx 16rpx 24rpx;
  margin-bottom: 18rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 24rpx;
}
.grid-card:active {
  transform: scale(0.95);
  background: rgba(22,119,255,0.05);
}
.grid-icon {
  width: 56rpx;
  height: 56rpx;
  display: block;
  margin: 0 auto 12rpx;
}
.grid-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}
.grid-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
.grid-empty {
  width: 100%;
  text-align: center;
  padding: 100rpx 0;
}

/* 标签云 */
.tag-section {
  padding: 20rpx 36rpx;
}
.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.tag-bubble {
  background: var(--bg-card);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  color: var(--text-secondary);
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 36rpx;
  border: 1rpx solid var(--border-glass);
  box-shadow: var(--shadow-card);
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tag-bubble:active {
  background: var(--brand-primary);
  color: #FFF;
  border-color: var(--brand-primary);
}

/* 空状态 */
.empty-icon-img {
  width: 90rpx;
  height: 90rpx;
  display: block;
  margin: 0 auto 16rpx;
  opacity: 0.35;
}
.empty-txt {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ===== iOS 18 悬浮胶囊 TabBar 底部预留（110rpx 胶囊 + 16rpx 间距 + 安全区） ===== */
.page-container {
  padding-bottom: 180rpx !important;
}
