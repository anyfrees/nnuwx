<view class="page-container">
  <!-- Segment 切换 -->
  <view class="seg-bar">
    <view class="seg-item {{activeTab === 'category' ? 'seg-active' : ''}}" bindtap="switchTab" data-tab="category">
      <image class="seg-icon" src="/images/icons/folder.png" mode="aspectFit"/> 分类
    </view>
    <view class="seg-item {{activeTab === 'tag' ? 'seg-active' : ''}}" bindtap="switchTab" data-tab="tag">
      <image class="seg-icon" src="/images/icons/tag.png" mode="aspectFit"/> 标签
    </view>
  </view>

  <!-- 分类九宫格 -->
  <view class="grid-container" wx:if="{{activeTab === 'category'}}">
    <block wx:for="{{categories}}" wx:key="name">
      <view class="grid-card card ripple fade-in" 
            style="animation-delay:{{index * 0.06}}s;"
            bindtap="onCategoryTap" data-name="{{item.name}}" data-icon="{{item.icon}}">
        <image class="grid-icon" src="{{item.icon}}" mode="aspectFit"/>
        <text class="grid-name">{{item.name}}</text>
        <text class="grid-count">{{item.count}} 篇</text>
      </view>
    </block>
    <!-- 空状态 -->
    <view class="grid-empty" wx:if="{{categories.length === 0}}">
      <image class="empty-icon-img" src="/images/icons/empty.png" mode="aspectFit"/>
      <text class="empty-txt">暂无分类数据</text>
    </view>
  </view>

  <!-- 标签云 -->
  <view class="tag-section" wx:if="{{activeTab === 'tag'}}">
    <view class="tag-cloud">
      <block wx:for="{{tags}}" wx:key="*this">
        <view class="tag-bubble fade-in" 
              style="animation-delay:{{index * 0.04}}s;"
              bindtap="onTagTap" data-name="{{item}}">
          {{item}}
        </view>
      </block>
    </view>
    <view class="grid-empty" wx:if="{{tags.length === 0}}">
      <image class="empty-icon-img" src="/images/icons/tag.png" mode="aspectFit"/>
      <text class="empty-txt">暂无标签数据</text>
    </view>
  </view>
</view>
