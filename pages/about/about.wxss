.feature-section {
  padding: 20rpx 30rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 20rpx;
}
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-start;
}
.feature-card {
  width: calc(33.33% - 8rpx);
  padding: 24rpx 12rpx;
  text-align: center;
  box-sizing: border-box;
}
.feature-icon-img {
  width: 48rpx;
  height: 48rpx;
  display: block;
  margin: 0 auto 10rpx;
}
.feature-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}
.feature-desc {
  font-size: 20rpx;
  color: var(--text-tertiary);
  display: block;
}

/* 链接 */
.links-section {
  padding: 20rpx 30rpx;
}
.link-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.link-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
}
.link-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}
.link-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.link-url {
  font-size: 22rpx;
  color: var(--text-tertiary);
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.link-copy {
  font-size: 22rpx;
  color: var(--brand-primary);
  padding: 6rpx 16rpx;
  background: rgba(22,119,255,0.08);
  border-radius: 12rpx;
}

/* 底部 */
.about-footer {
  text-align: center;
  padding: 48rpx 36rpx 80rpx;
}
.footer-copy {
  font-size: 22rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 4rpx;
}
