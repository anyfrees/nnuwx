.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 36rpx;
}
.header-count { font-size: 24rpx; color: var(--text-tertiary); }
.clear-btn { font-size: 24rpx; color: #EF4444; }

.history-list {
  padding: 0 30rpx;
}

.history-card {
  display: flex;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  padding: 0;
  background: var(--bg-card);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-glass);
  overflow: hidden;
}
.hist-content {
  flex: 1;
  padding: 24rpx 28rpx;
}
.hist-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}
.hist-excerpt {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 12rpx;
}
.hist-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
}
.hist-cat { color: var(--brand-primary); max-width: 140rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: inline-block; }
.hist-date { color: var(--text-tertiary); }

.empty-state { text-align: center; padding: 200rpx 40rpx; }
.empty-icon-img {
  width: 100rpx;
  height: 100rpx;
  display: block;
  margin: 0 auto 20rpx;
  opacity: 0.35;
}
.empty-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); display: block; margin-bottom: 10rpx; }
.empty-desc { font-size: 26rpx; color: var(--text-tertiary); display: block; }
