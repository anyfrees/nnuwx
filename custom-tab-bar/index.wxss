.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 68rpx;
  padding-bottom: env(safe-area-inset-bottom);
  margin: 0 32rpx 20rpx;
  background: rgba(255, 255, 255, 0.10);
  backdrop-filter: blur(50px) saturate(200%);
  -webkit-backdrop-filter: blur(50px) saturate(200%);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 999rpx;
  box-shadow:
    0 4rpx 20rpx rgba(0, 0, 0, 0.05),
    0 1rpx 6rpx rgba(0, 0, 0, 0.03),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.20);
  z-index: 999;
  box-sizing: content-box;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0;
  gap: 2rpx;
  transition: all 0.25s ease;
  position: relative;
  transform: translateY(0);
}

.tab-bar-item:active {
  transform: scale(0.92);
  opacity: 0.7;
}

.tab-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.tab-text {
  font-size: 20rpx;
  color: #1A1A2E;
  font-weight: 500;
  line-height: 1.2;
  transition: color 0.25s ease;
  flex-shrink: 0;
}

.tab-text-active {
  color: #1677FF;
  font-weight: 700;
}
